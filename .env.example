# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# Resend API key — used by server.js to send transactional email
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret used by server.js when logging outbound emails
# into Convex (via the /messages/log-outbound httpAction). The
# SAME value must be set on the Convex deployment:
#     npx convex env set INTERNAL_API_SECRET <value>
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-me-with-a-long-random-string

# Optional. When set on the Convex deployment, the inbound webhook
# (/resend/inbound) verifies the Svix signature Resend includes on
# every payload. Get this value from the Resend dashboard when you
# wire up the inbound route.
#     npx convex env set RESEND_WEBHOOK_SECRET <whsec_value>
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
